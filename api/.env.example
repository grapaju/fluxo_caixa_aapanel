# API
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Cookies
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Database
# Local (testes)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/fluxocash?schema=public

# VPS aaPanel (exemplo)
# DATABASE_URL=postgresql://fluxocash_user:senha_forte@127.0.0.1:5432/fluxocash?schema=public
